# Jarvis platform secrets. Copy to .env and fill in.
# .env is gitignored — never commit it.

# --- Postgres (LiteLLM spend ledger + dashboard) ---
POSTGRES_USER=jarvis
POSTGRES_PASSWORD=changeme-generate-a-random-one
POSTGRES_DB=jarvis

# --- LiteLLM (Phase 2) ---
# Master admin key for the LiteLLM proxy /ui and admin API.
LITELLM_MASTER_KEY=sk-changeme-generate-a-random-one
# Salt used to encrypt provider keys at rest in the LiteLLM DB.
LITELLM_SALT_KEY=changeme-generate-a-random-one

# --- OpenRouter (Phase 2) ---
# Get one at https://openrouter.ai/keys — paste it into .env, not here.
OPENROUTER_API_KEY=

# --- Per-project virtual keys with budgets (Phase 3, auto-created by 03_keys.sh) ---
# One per knowledge-engine project. To add a project, append a line here, add the
# project to setup/03_keys.sh, then re-run it (see "Add a new project" in README).
HEDGEFUND_LLM_KEY=
MSME_LLM_KEY=
JARVIS_LLM_KEY=
