# ─── Secrets — never commit ───────────────────────────────────────
.env
*.env
!*.env.example
platform/.env
*.key
*.pem
*credentials*
*secret*

# ─── Python virtual environments ──────────────────────────────────
.venv/
**/.venv/
.venv-test/
venv/
env/

# ─── Python build / cache artifacts ───────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ─── Knowledge-graph data (per-project, regenerated by ingestion) ──
# Holds ingested documents, uploads, and the Cognee/FalkorDB working
# state — project-specific and potentially sensitive. Never publish.
cognee/data/

# ─── Runtime logs & generated reports ─────────────────────────────
*.log
dashboard/dashboard.log
bench/bench-reports/

# ─── Local tooling / editor / OS ──────────────────────────────────
.claude/
.idea/
.vscode/
.DS_Store
Thumbs.db
