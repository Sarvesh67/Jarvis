# Modelfile for Llama-Open-Finance-8B (Q4_K_M quantization).
# Generated from DragonLLM/Llama-Open-Finance-8B and quantized locally.
#
# This file is consumed by `ollama create` after the GGUF is built. The path
# below is replaced by setup/03_install_ollama.sh at install time.

FROM __GGUF_PATH__

# --- chat template (Llama-3.1 instruct format) ---
TEMPLATE """<|begin_of_text|>{{ if .System }}<|start_header_id|>system<|end_header_id|>

{{ .System }}<|eot_id|>{{ end }}{{ if .Prompt }}<|start_header_id|>user<|end_header_id|>

{{ .Prompt }}<|eot_id|>{{ end }}<|start_header_id|>assistant<|end_header_id|>

{{ .Response }}<|eot_id|>"""

PARAMETER stop "<|eot_id|>"
PARAMETER stop "<|start_header_id|>"
PARAMETER stop "<|end_header_id|>"

# --- inference parameters tuned for structured extraction ---
# Low temperature → more deterministic YAML output.
# Top-p 0.9 → some diversity for tricky entities, not so high it hallucinates tickers.
PARAMETER temperature 0.2
PARAMETER top_p 0.9
PARAMETER top_k 40
PARAMETER repeat_penalty 1.05

# Context window: Llama-3.1 supports 128K. We don't need that for per-article
# extraction; cap at 8K to keep memory predictable on the M4.
PARAMETER num_ctx 8192

# --- system prompt for Pass 1 extraction ---
# Skills can override this per-call; this is the default if a skill doesn't
# specify a system message.
SYSTEM """You are a financial-news extraction assistant. Your job is to read a single news article and emit a YAML document with a fixed 12-field schema. Output ONLY the YAML, no preamble, no commentary.

Schema:
  source: <publication name>
  url: <article url>
  published_at: <ISO 8601 timestamp or null>
  headline: <verbatim headline>
  instruments: [<list of tickers in NSE/BSE format, e.g. RELIANCE.NS>]
  entities:
    companies: []
    people: []
    regulators: []
  event_type: <one of: earnings, mna, regulatory, management_change, dividend, ipo, downgrade, upgrade, other>
  event_subtype: <free-text refinement, optional>
  sentiment_label: <positive | negative | neutral>
  sentiment_confidence: <float 0.0-1.0>
  is_market_moving: <true | false>
  notes: <one-sentence summary, optional>

Rules:
- If a field is unknown, use null. Never invent.
- Tickers must use NSE (.NS) or BSE (.BO) suffix when applicable to Indian markets.
- Output must parse as valid YAML."""
