# Secrets for the Hermes brain router.
# Copy to /Users/hedgefund/brain-stub/.env (chmod 600, owned by hedgefund).
# DO NOT commit the real file — only this .example template lives in git.
#
# DEFAULTS (baked in server.py + plist) — only override if you want different behavior:
#   BRAIN_BRIDGE_URL    = https://openrouter.ai/api/v1/chat/completions
#   ROUTER_HAIKU_MODEL  = anthropic/claude-haiku-4.5
#   ROUTER_SONNET_MODEL = anthropic/claude-sonnet-4.6
#   ROUTER_OPUS_MODEL   = anthropic/claude-opus-4.7

BRAIN_BRIDGE_API_KEY=sk-or-v1-REPLACE_ME

# ---------------------------------------------------------------------------
# OPTIONAL: per-tier model overrides
# ---------------------------------------------------------------------------
# The router maps three stable TIER LABELS (claude-haiku-4 / -sonnet-4 / -opus-4)
# to whatever upstream model you want. Mix and match for cost vs quality.
#
# Example — keep Claude Opus 4.7 for hardest reasoning, but use OpenAI's tiny
# model for cheap orchestration calls (~7× cheaper than Anthropic Haiku):
# ROUTER_HAIKU_MODEL=openai/gpt-4o-mini
# ROUTER_SONNET_MODEL=anthropic/claude-sonnet-4.6
# ROUTER_OPUS_MODEL=anthropic/claude-opus-4.7
#
# Or pure best-of-breed reasoning at every tier:
# ROUTER_HAIKU_MODEL=anthropic/claude-haiku-4.5
# ROUTER_SONNET_MODEL=anthropic/claude-sonnet-4.6
# ROUTER_OPUS_MODEL=anthropic/claude-opus-4.7
#
# See https://openrouter.ai/models for the full catalog and pricing.

# ---------------------------------------------------------------------------
# OPTIONAL: provider swaps (rare — full URL change)
# ---------------------------------------------------------------------------
# # Raw OpenAI direct (cheaper than via OpenRouter):
# # BRAIN_BRIDGE_URL=https://api.openai.com/v1/chat/completions
# # ROUTER_HAIKU_MODEL=gpt-4o-mini
# # ROUTER_SONNET_MODEL=gpt-4o
# # ROUTER_OPUS_MODEL=o1-mini
#
# # Raw Anthropic API direct (lower cost, but our router speaks OpenAI format
# # not Anthropic Messages — would need router code changes to use this):
# # BRAIN_BRIDGE_URL=https://api.anthropic.com/v1/messages

# ---------------------------------------------------------------------------
# OPTIONAL tuning (defaults in server.py are sensible):
# BRAIN_BUDGET_SOFT=50000
# BRAIN_BUDGET_HARD=100000
# BRAIN_MAX_OUTPUT=2000
